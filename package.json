{
  "name": "portfolio-website",
  "version": "1.0.0",
  "description": "A professional Jekyll portfolio website",
  "scripts": {
    "build": "npm run build:css && npm run build:js && JEKYLL_ENV=production bundle exec jekyll build",
    "build:css": "lightningcss --minify assets/css/styles.css -o assets/css/styles.min.css",
    "build:js": "rolldown -c rolldown.config.mjs",
    "dev": "npm run build:css && concurrently \"npm run watch:css\" \"npm run watch:js\" \"npm run serve\"",
    "watch:css": "lightningcss --minify --watch assets/css/styles.css -o assets/css/styles.min.css",
    "fix": "npm run fix:css && npm run fix:js && npm run fix:md",
    "fix:css": "stylelint 'assets/css/styles.css' --fix",
    "fix:js": "biome check --fix .",
    "fix:md": "markdownlint '**/*.md' --fix",
    "lint": "npm run lint:css && npm run lint:js && npm run lint:md && npm run lint:fallow",
    "lint:all": "npm run build && npm run lint && npm run lint:html",
    "lint:css": "stylelint 'assets/css/styles.css'",
    "lint:fallow": "fallow",
    "lint:html": "htmlhint '_site/**/*.html' --ignore '**/playwright-report/**'",
    "lint:js": "biome check .",
    "lint:md": "markdownlint '**/*.md'",
    "prepare": "husky install",
    "serve": "bundle exec jekyll serve",
    "setup": "npm install && bundle install",
    "test": "playwright test",
    "test:update": "playwright test --update-snapshots",
    "watch:js": "npm run build:js -- --watch"
  },
  "keywords": [
    "portfolio",
    "jekyll"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.css": "stylelint --fix",
    "*.js": "biome check --fix",
    "*.md": "markdownlint --fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2",
    "fallow": "^2.73.0",
    "htmlhint": "^1.1.4",
    "husky": "^9.0.0",
    "lightningcss-cli": "^1.32.0",
    "lint-staged": "^16.2.7",
    "markdownlint-cli": "^0.48.0",
    "rolldown": "^1.0.0-rc.10",
    "stylelint": "^17.3.0"
  }
}
